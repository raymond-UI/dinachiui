{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@dinachi/core": ["./packages/core/src/index.ts"],
      "@dinachi/core/*": ["./packages/core/src/*"],
      "@dinachi/components": ["./packages/components/src/index.ts"],
      "@dinachi/components/*": ["./packages/components/src/*"]
    }
  },
  "include": ["packages/*/src"],
  "exclude": ["**/*.test.*", "**/*.spec.*", "node_modules"]
}
