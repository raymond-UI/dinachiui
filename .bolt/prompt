## Phase 8: Advanced Features

### 8.1 Theme System
```typescript
// packages/core/src/theme/theme-provider.tsx
import { createContext, useContext } from 'react'

interface Theme {
  colors: Record<string, string>
  spacing: Record<string, string>
  typography: Record<string, any>
}

const ThemeContext = createContext<Theme | null>(null)

export function ThemeProvider({ 
  children, 
  theme 
}: { 
  children: React.ReactNode
  theme: Theme 
}) {
  return (
    <ThemeContext.Provider value={theme}>
      {children}
    </ThemeContext.Provider>
  )
}

export function useTheme() {
  const theme = useContext(ThemeContext)
  if (!theme) {
    throw new Error('useTheme must be used within ThemeProvider')
  }
  return theme
}
```

### 8.2 CSS-in-JS Support
Provide styled-components and emotion variants:

```typescript
// packages/components/src/button/button.styled.tsx
import styled from 'styled-components'
import { Button as BaseButton } from '@base-ui-components/react/button'

export const Button = styled(BaseButton)<{ variant?: string }>`
  display: inline-flex;
  align-items: center;
  justify-content: center;
  
  ${({ variant, theme }) => {
    switch (variant) {
      case 'primary':
        return `
          background-color: ${theme.colors.primary};
          color: ${theme.colors.white};
        `
      default:
        return `
          background-color: ${theme.colors.gray[100]};
          color: ${theme.colors.gray[900]};
        `
    }
  }}
`
```

