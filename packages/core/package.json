{
  "name": "@dinachi/core",
  "version": "0.0.0",
  "description": "Core utilities and styling helpers for Dinachi UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "ui",
    "react",
    "tailwind",
    "utils",
    "dinachi"
  ],
  "author": "Dinachi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raymond-UI/dinachiUI"
  },
  "homepage": "https://dinachi.dev",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
