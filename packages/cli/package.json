{
  "name": "@dinachi/cli",
  "version": "0.6.2",
  "description": "CLI for adding Dinachi UI components to your project",
  "type": "module",
  "keywords": [
    "ui",
    "components",
    "cli",
    "dinachi",
    "react",
    "tailwind"
  ],
  "author": "Dinachi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dinachi/ui.git"
  },
  "homepage": "https://dinachi.dev",
  "bin": {
    "dinachi": "dist/index.js",
    "dinachi-ui": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "pnpm run build && node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.2",
    "ora": "^9.0.0",
    "prompts": "^2.4.2",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@base-ui/react": "1.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "0.552.0",
    "react": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.0.1",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
