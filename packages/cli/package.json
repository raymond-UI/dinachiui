{
  "name": "@dinachi/cli",
  "version": "0.3.2",
  "description": "CLI for adding Dinachi UI components to your project",
  "type": "module",
  "keywords": [
    "ui",
    "components",
    "cli",
    "dinachi",
    "react",
    "tailwind"
  ],
  "author": "Dinachi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dinachi/ui"
  },
  "homepage": "https://dinachi.dev",
  "bin": {
    "dinachi": "./dist/index.js",
    "dinachi-ui": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "prompts": "^2.4.2",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.2",
    "execa": "^8.0.1",
    "ts-morph": "^20.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.1",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
