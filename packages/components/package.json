{
  "name": "@dinachi/components",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-beta.0",
    "@dinachi/core": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "react": "19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "26.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  }
}