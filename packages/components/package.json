    "lucide-react": "0.552.0",
    "react": "19.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "5.1.0",
    "jsdom": "27.0.0",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "vitest": "4.0.5"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0"
  }
