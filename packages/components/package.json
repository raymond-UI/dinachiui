{
  "name": "@dinachi/components",
  "version": "0.0.0",
  "description": "Dinachi UI React components built with Base UI primitives",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "ui",
    "components",
    "react",
    "base-ui",
    "dinachi"
  ],
  "author": "Dinachi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dinachi/ui"
  },
  "homepage": "https://dinachi.dev",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@base-ui/react": "1.2.0",
    "@dinachi/core": "workspace:*",
    "class-variance-authority": "0.7.1",
    "lucide-react": "0.552.0"
  },
  "devDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@testing-library/dom": "^10.4.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "5.1.0",
    "jsdom": "27.0.0",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "vitest": "4.0.5"
  },
  "peerDependencies": {
    "react": ">=19.2.4",
    "react-dom": ">=19.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
