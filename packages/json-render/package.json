{
  "name": "@dinachi/json-render",
  "version": "0.1.0",
  "description": "DinachiUI component adapter for json-render. JSON becomes accessible Base UI-powered React components.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js",
      "require": "./dist/catalog.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest"
  },
  "dependencies": {
    "@json-render/core": "^0.5.0",
    "@json-render/react": "^0.5.0",
    "@dinachi/components": "workspace:*",
    "@dinachi/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "vitest": "4.0.5",
    "zod": "^4.0.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "jsdom": "27.0.0"
  },
  "peerDependencies": {
    "react": ">=19.2.4",
    "react-dom": ">=19.2.4",
    "zod": ">=4.0.0"
  },
  "keywords": [
    "dinachi",
    "json-render",
    "generative-ui",
    "react",
    "base-ui",
    "ui-components"
  ],
  "author": "Dinachi Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
