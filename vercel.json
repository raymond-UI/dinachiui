{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/docs && pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": "apps/docs/.next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./apps/docs/",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/components",
      "destination": "/docs/components",
      "permanent": true
    },
    {
      "source": "/installation",
      "destination": "/docs/installation", 
      "permanent": true
    }
  ]
}